{
  "execution": {
    "mode": "paperbroker",
    "timeout_seconds": 10,
    "retry_attempts": 3,
    "retry_delay_seconds": 1
  },

  "paperbroker": {
    "fix": {
      "host": "${PAPERBROKER_FIX_HOST}",
      "port": "${PAPERBROKER_FIX_PORT}",
      "sender_comp_id": "${PAPERBROKER_SENDER_COMP_ID}",
      "target_comp_id": "${PAPERBROKER_TARGET_COMP_ID}",
      "username": "${PAPERBROKER_FIX_USERNAME}",
      "password": "${PAPERBROKER_FIX_PASSWORD}",
      "heartbeat_interval": 30,
      "logon_timeout": 10
    },

    "rest": {
      "base_url": "${PAPERBROKER_REST_BASE_URL}",
      "timeout": 5
    },

    "trading": {
      "default_sub_account": "${PAPERBROKER_SUB_ACCOUNT}",
      "contracts": ["VN30F2511", "VN30F2512"],
      "exchange": "HNXDS",
      "auto_resolve_contracts": true
    },

    "risk": {
      "max_pending_orders": 10,
      "order_timeout_seconds": 60,
      "reconnect_on_disconnect": true,
      "max_reconnect_attempts": 5
    }
  },

  "market_data": {
    "source": "redis",
    "redis": {
      "host": "${MARKET_REDIS_HOST}",
      "port": "${MARKET_REDIS_PORT}",
      "channel_prefix": "market"
    }
  },

  "strategy": {
    "initial_capital": 500000,
    "step": 2.9,
    "update_interval_seconds": 15
  },

  "audit": {
    "enabled": true,
    "log_path": "logs/audit/paperbroker_session.log",
    "include_latency_metrics": true
  }
}