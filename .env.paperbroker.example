# PaperBroker FIX Connection Configuration
# Copy this file to .env.paperbroker and fill in your credentials
# NEVER commit the actual .env.paperbroker file to version control

# FIX Connection Settings
PAPERBROKER_FIX_HOST=your.paperbroker.host
PAPERBROKER_FIX_PORT=5001
PAPERBROKER_SENDER_COMP_ID=PMM-TRADER-01
PAPERBROKER_TARGET_COMP_ID=SERVER

# FIX Authentication (obtain from PaperBroker)
PAPERBROKER_FIX_USERNAME=your_fix_username
PAPERBROKER_FIX_PASSWORD=your_fix_password

# REST API Settings
PAPERBROKER_REST_BASE_URL=http://your.paperbroker.host:9090

# Trading Configuration
PAPERBROKER_SUB_ACCOUNT=D1
# Comma-separated list of contract codes
PAPERBROKER_CONTRACTS=VN30F2511,VN30F2512

# Note: Redis configuration is managed in .env.redis
# See .env.redis.example for Redis settings

# Execution Mode (mock or paperbroker)
EXECUTION_MODE=paperbroker

# Optional: Override strategy parameters
# STRATEGY_INITIAL_CAPITAL=500000
# STRATEGY_STEP=2.9
# STRATEGY_UPDATE_INTERVAL=15