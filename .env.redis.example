# Redis Configuration Template
# Copy this to .env.redis and configure for your Redis instance

# Redis Connection Settings
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Redis Authentication (leave empty if no password required)
REDIS_PASSWORD=

# Redis Decoding Options
# Set to true to decode responses to strings, false to keep as bytes
REDIS_DECODE_RESPONSES=true

# Channel Configuration
# Prefix for Redis channel names (e.g., "market" creates channels like "market:VN30F2511")
REDIS_CHANNEL_PREFIX=market

# Contract Configuration
# Comma-separated list of contracts to trade (abstract symbols like VN30F1M or concrete codes like VN30F2511)
REDIS_CONTRACTS=VN30F1M,VN30F2M

# Contract Symbol Resolution
# Set to true to automatically resolve VN30F1M/VN30F2M to actual contract codes based on expiration dates
# Set to false to use manual mappings from CONTRACT_MAPPINGS
AUTO_DETECT_CONTRACTS=false

# Contract Mappings (JSON format, optional)
# Maps abstract symbols to concrete contract codes
# Example: {"VN30F1M":"VN30F2511","VN30F2M":"VN30F2512"}
# Leave empty if using AUTO_DETECT_CONTRACTS=true or if you want to use redis_config.json
CONTRACT_MAPPINGS=

# Connection Options
REDIS_SOCKET_CONNECT_TIMEOUT=5
REDIS_SOCKET_KEEPALIVE=true
REDIS_HEALTH_CHECK_INTERVAL=30

# Note: For production Redis with authentication, set:
# REDIS_PASSWORD=your_secure_password_here
#
# Example for external server with specific channel prefix:
# REDIS_HOST=1.55.212.27
# REDIS_PORT=6381
# REDIS_PASSWORD=your_password_here
# REDIS_CHANNEL_PREFIX=HNXDS
# AUTO_DETECT_CONTRACTS=true